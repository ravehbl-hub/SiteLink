# SiteLink — environment surface (documented; real values live in Vercel/Railway/Supabase)
# Copy to .env for local dev. NEVER commit real secrets.

# ── Database (Supabase managed Postgres) ─────────────────────────────────────
# Runtime client → Supabase connection pooler (PgBouncer, port 6543).
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma Migrate → Supabase direct connection (port 5432, non-pooled).
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Supabase Auth + Storage ──────────────────────────────────────────────────
# Project URL (safe to expose to clients).
SUPABASE_URL="https://<ref>.supabase.co"
# Anon/publishable key (clients: web + native).
SUPABASE_ANON_KEY="<anon-key>"
# Service-role key — BACK END ONLY. Never sent to any client.
# Used for Admin API (user provisioning) and minting signed Storage URLs.
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
# For verifying incoming Supabase JWTs on the back end (secret or JWKS endpoint).
SUPABASE_JWT_SECRET="<jwt-secret>"

# ── Back end (Fastify on Railway) ────────────────────────────────────────────
PORT="4000"
LOG_LEVEL="info"
NODE_ENV="development"

# ── Web front ends (Vite) — must be prefixed VITE_ to be exposed ─────────────
VITE_API_BASE_URL="http://localhost:4000/api/v1"
VITE_SUPABASE_URL="https://<ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<anon-key>"

# ── App front ends (Expo) — must be prefixed EXPO_PUBLIC_ to be exposed ──────
EXPO_PUBLIC_API_BASE_URL="http://localhost:4000/api/v1"
EXPO_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
