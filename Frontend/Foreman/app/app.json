{
  "expo": {
    "name": "SiteLink Foreman",
    "slug": "sitelink-foreman-app",
    "scheme": "sitelink-foreman",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitelink.foreman",
      "infoPlist": {
        "NSCameraUsageDescription": "SiteLink uses the camera to capture worker profile photos.",
        "NSPhotoLibraryUsageDescription": "SiteLink accesses your photos to attach worker profile images."
      }
    },
    "android": {
      "package": "com.sitelink.foreman",
      "permissions": ["CAMERA", "READ_MEDIA_IMAGES"]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "SiteLink uses the camera to capture worker profile photos."
        }
      ],
      "expo-secure-store"
    ]
  }
}
