{
  "expo": {
    "name": "SiteLink Foreman",
    "slug": "sitelink-foreman-app",
    "scheme": "sitelink-foreman",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sitelink.foreman"
    },
    "android": {
      "package": "com.sitelink.foreman"
    },
    "plugins": ["expo-secure-store"]
  }
}
