# SiteLink Manager App — Expo public env (client-side, publishable values only).
# Copy to .env and fill. NEVER put the Supabase service-role key here — it is
# back-end only (Architecture §8). Only EXPO_PUBLIC_* vars are exposed to the app.

# Fastify back end base URL, including the /api/v1 prefix.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Supabase project URL and publishable anon key (used by the Supabase SDK for
# authentication and for direct signed-URL object transfer).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
