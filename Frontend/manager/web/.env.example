# @sitelink/manager-web — client env surface (Architecture §8). Never commit real secrets.
# Base URL of the Fastify back end (includes the /api/v1 prefix).
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Supabase project — publishable client values only (never the service-role key).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
