// SiteLink — Prisma schema (Phase 01 / CREATE)
// Owner: Lattice (Schema). Authoritative data model for the Fastify back end.
//
// Conventions:
//   - Enum members are SCREAMING_SNAKE_CASE and MUST match @sitelink/shared/src/enums.ts
//     and docs/SCHEMA.md byte-for-byte.
//   - Every persisted model has createdAt / updatedAt.
//   - Soft-delete / archives use isArchived (+ archivedAt) per PRD FR-MGR-EMP-5/6, FR-MGR-SITE.
//   - [v1] models power the Manager surface + back end. [future] models are modeled now
//     to avoid migration churn (PRD FR-REQ-3, §10 FR-BO) but are unused by v1 surfaces.

generator client {
  provider = "prisma-client-js"
  // Prisma 7 + pg driver adapter (see ../prisma.config.ts + ../src/db/client.ts):
  // the runtime PrismaClient is constructed with @prisma/adapter-pg on DATABASE_URL.
  // (driverAdapters is GA in Prisma 7 — no previewFeatures flag needed.)
  // Generated client output — imported via the `@sitelink/backend` generated path
  // (Prisma 7 requires an explicit output; this keeps it inside the workspace).
  output = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // Managed by Supabase. Connection URLs live in ../prisma.config.ts (Prisma 7+):
  //   runtime  → DATABASE_URL = Supabase pooler (PgBouncer, :6543, ?pgbouncer=true)
  //   migrate  → DIRECT_URL   = Supabase direct connection (:5432)
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (mirror @sitelink/shared/src/enums.ts)
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  PARTNER
  FOREMAN
  WORKER
}

enum Profession {
  IRONWORKER
  MOLDER
  CONCRETE_WORKER
  GENERAL_LABORER
  FOREMAN
  MECHANIC
  ELECTRICIAN
  PLUMBER
  OTHER
}

enum WorkerLevel {
  WEAK
  MEDIUM
  GOOD
  EXCELLENT
}

enum AttendanceType {
  ATTENDANCE
  VACATION
  DISEASE
}

enum WorkerDocType {
  PASSPORT_ID
  VISA
  HEIGHT_PERMIT
  ATTAT
}

enum SalaryCalcMode {
  ISRAELI_LABOR_LAW
  FIXED
}

enum RateType {
  HOURLY
  MONTHLY
}

enum SiteStatus {
  ACTIVE
  ARCHIVED
}

enum RequestType {
  VACATION
  LOAN
  ADVANCE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum Language {
  HE
  EN
  TR
}

enum Theme {
  LIGHT
  DARK
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

// ─────────────────────────────────────────────────────────────────────────────
// Users & Auth  [v1]  (PRD FR-MGR-USER, FR-X-RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  // Supabase Auth user id (identity FK). Credentials/sessions/password reset are
  // owned by Supabase Auth; this row owns authorization (role + site scope).
  // No password hash is stored here (NFR-SEC-1) — Supabase holds credentials.
  authUserId    String    @unique
  role          Role
  fullName      String
  email         String    @unique
  isLockedOut   Boolean   @default(false) // reversible lockout (FR-MGR-USER-3)
  language      Language  @default(HE)
  theme         Theme     @default(LIGHT)
  lastLoginAt   DateTime?

  // ── Multi-tenancy (Phase 1) — the tenant this user belongs to (the app's biggest
  // security boundary). Every User carries a DIRECT companyId (Manager sees ONLY
  // same-company users/data; ADMIN is super-admin above all companies). Nullable in the
  // schema history for a zero-orphan backfill (add nullable → backfill to Default Company
  // → verify zero nulls → SET NOT NULL, all in ONE migration) — the FINAL DB state is
  // NOT NULL. onDelete: Restrict — a Company with users can never be hard-deleted
  // (tenants are retired via Company.isArchived soft-archive, never cascade). Servio's
  // resolveCompanyScope + Users-surface scoping AND this with site/self scope.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  primarySite   Site?     @relation("UserPrimarySite", fields: [primarySiteId], references: [id])
  primarySiteId String?

  // Requests this user resolved as Admin/Manager (future workflow)
  resolvedRequests WorkerRequest[] @relation("RequestResolvedBy")

  // Worker ratings this user authored as a FOREMAN (FR-FOR-5)
  authoredRatings  WorkerRating[]  @relation("RatingByForeman")

  // Optional 1:1 link to the Worker record this login represents (Phase 05 self-scoping).
  // Named relation to avoid clashing with "RequestResolvedBy"/"RatingByForeman".
  worker    Worker?  @relation("WorkerLogin")

  // Multi-site scope for a FOREMAN user (security-boundary change). primarySiteId above
  // stays the DEFAULT/primary site; these are the additional/authoritative ASSIGNED sites.
  foremanSiteAssignments ForemanSiteAssignment[] @relation("ForemanSiteScope")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authUserId])
  @@index([role])
  @@index([primarySiteId])
  // Multi-tenancy scope indexes: companyId is the hot filter on EVERY scoped query
  // (where: { companyId }); [companyId, role] serves the role-visibility hot path
  // (e.g. list MANAGERs/FOREMEN within a company).
  @@index([companyId])
  @@index([companyId, role])
}

// ─────────────────────────────────────────────────────────────────────────────
// Sites  [v1]  (PRD FR-MGR-SITE)
// ─────────────────────────────────────────────────────────────────────────────

model Site {
  id         String     @id @default(cuid())
  name       String
  code       String?
  status     SiteStatus @default(ACTIVE)
  address    String?
  startedAt  DateTime?
  isArchived Boolean    @default(false)
  archivedAt DateTime?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Sites are independently listed/
  // filtered and anchor many derivations (assignments, attendance, wage rates, P&L).
  // Backfilled to the Default Company (existing sites have no owner link today).
  // NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  users            User[]                  @relation("UserPrimarySite")
  assignments      SiteAssignment[]
  foremanScope     ForemanSiteAssignment[] @relation("ForemanSiteScope")
  attendance  AttendanceRecord[]
  wageRates   ProfessionWageRate[]
  profitLoss  ProfitLoss[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([isArchived])
  // Multi-tenancy scope indexes: companyId hot filter + [companyId, status] /
  // [companyId, isArchived] for the per-company active/archived site lists.
  @@index([companyId])
  @@index([companyId, status])
  @@index([companyId, isArchived])
}

// Worker ⇄ Site many-to-many (FR-MGR-SITE-4)
model SiteAssignment {
  id           String    @id @default(cuid())
  site         Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId       String
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId     String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, workerId])
  @@index([workerId])
}

// Foreman ⇄ Site many-to-many (multi-site Foreman scope; security-boundary change).
// Mirrors SiteAssignment's shape/semantics: an active assignment has unassignedAt = null;
// re-assigning an existing (foremanId, siteId) pair REACTIVATES the same row (clear
// unassignedAt) rather than inserting a duplicate — enforced by @@unique([foremanId, siteId]).
//
// The foreman relation is named "ForemanSiteScope" to avoid clashing with User's
// existing relations ("RatingByForeman", "RequestResolvedBy", "WorkerLogin",
// "UserPrimarySite"). User.primarySiteId is KEPT as the foreman's DEFAULT/primary site;
// these rows are the foreman's ASSIGNED scope set. Scope-union logic is Servio's (scope.ts).
model ForemanSiteAssignment {
  id           String    @id @default(cuid())
  site         Site      @relation("ForemanSiteScope", fields: [siteId], references: [id], onDelete: Cascade)
  siteId       String
  foreman      User      @relation("ForemanSiteScope", fields: [foremanId], references: [id], onDelete: Cascade)
  foremanId    String
  assignedAt   DateTime  @default(now())
  unassignedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([foremanId, siteId])
  @@index([foremanId])
  @@index([siteId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Workers, Docs, Salary data  [v1]  (PRD FR-MGR-EMP)
// ─────────────────────────────────────────────────────────────────────────────

model Worker {
  id               String      @id @default(cuid())
  firstName        String // required (FR-MGR-EMP-7)
  lastName         String // required (FR-MGR-EMP-7)
  country          String?
  address          String?
  profession       Profession // required (FR-MGR-EMP-7/8)
  level            WorkerLevel @default(MEDIUM) // (FR-MGR-EMP-9)
  qualityOfWorks   String?
  phone            String?
  email            String?
  // Legacy free-text personnel/staffing company. KEPT one migration step alongside the new
  // FK (personnelCompanyId) so nothing is lost and Servio's in-flight worker edits don't
  // break on a missing column. A LATER migration drops this once the FK is fully wired +
  // the manager FE is cut over to the picker. Data migration backfills personnelCompanyId
  // from the DISTINCT non-empty values of this column (see add_personnel_company migration).
  personnelCompany String?
  // Managed personnel-company link (nullable). The relation field is named
  // `personnelCompanyRef` because the legacy free-text column above already owns the
  // `personnelCompany` name for now; downstream code selects the FK id via
  // `personnelCompanyId` and the joined row via `personnelCompanyRef`.
  // onDelete: SetNull — deleting a company unlinks its workers rather than deleting them.
  personnelCompanyRef PersonnelCompany? @relation(fields: [personnelCompanyId], references: [id], onDelete: SetNull)
  personnelCompanyId  String?
  residence        String?
  startDate        DateTime?

  // Profile image stored as an access-controlled file (FR-MGR-EMP-2)
  imageStorageKey  String?
  imageFileName    String?
  imageMimeType    String?
  imageUploadedAt  DateTime?

  isArchived Boolean   @default(false) // move-to-archives (FR-MGR-EMP-5/6)
  archivedAt DateTime?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. A login-less/demo worker has NO
  // User, so company CANNOT derive from User — Worker needs its own column. Backfilled
  // via User.companyId when userId is set, else COALESCE to the Default Company.
  // NOT NULL final state; onDelete: Restrict (a Company with workers is never hard-deleted).
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  // Optional, UNIQUE 1:1 link to the User login for this worker (Phase 05 self-scoping).
  // NULLABLE — existing workers have no login; linking is optional per the create flow.
  // Safe join key (never email). onDelete: SetNull — deleting the login unlinks, not deletes.
  loginUser User?     @relation("WorkerLogin", fields: [userId], references: [id], onDelete: SetNull)
  userId    String?   @unique

  docs        WorkerDoc[]
  salaryData  WorkerSalaryData?
  assignments SiteAssignment[]
  attendance  AttendanceRecord[]
  loans       Loan[]
  advances    AdvancePayment[]
  requests    WorkerRequest[]
  ratings     WorkerRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([profession])
  @@index([level])
  @@index([isArchived])
  @@index([personnelCompanyId])
  // Multi-tenancy scope indexes: companyId is the hot filter on worker lists; the
  // composites serve the core Manager screens ([companyId, isArchived] active/archived
  // lists; [companyId, profession] profession filters).
  @@index([companyId])
  @@index([companyId, isArchived])
  @@index([companyId, profession])
}

model WorkerDoc {
  id          String        @id @default(cuid())
  worker      Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId    String
  type        WorkerDocType
  reference   String?
  expiresAt   DateTime?

  // FileRef (retains file type + upload timestamp — FR-MGR-EMP-3)
  storageKey  String
  fileName    String
  mimeType    String
  sizeBytes   Int?
  uploadedAt  DateTime      @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([type])
}

model WorkerSalaryData {
  id                String   @id @default(cuid())
  worker            Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId          String   @unique
  hourlyWage        Decimal  @db.Decimal(12, 2)
  rateType          RateType @default(HOURLY)
  workingConditions String?
  currency          String   @default("ILS")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────────────────────
// Personnel / staffing companies  [v1]  (managed entity)
// Promotes the former free-text Worker.personnelCompany into a first-class,
// dedupable, editable entity (name + contact). Workers link via
// Worker.personnelCompanyId (nullable FK, onDelete: SetNull). `name` is UNIQUE:
// the backfill dedupes distinct free-text values case-insensitively into one row
// each, and the manager picker/CRUD (Servio) relies on name uniqueness to avoid
// duplicate companies. Follows the same conventions as Site/Customer.
// ─────────────────────────────────────────────────────────────────────────────

model PersonnelCompany {
  id          String  @id @default(cuid())
  // Per-company unique (was global `name @unique`) — Company A's "Acme Staffing" is not
  // Company B's. Uniqueness now scoped by @@unique([companyId, name]) below.
  name        String
  contactName String?
  phone       String?
  email       String?
  isArchived  Boolean @default(false)

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Staffing-firm directory is
  // tenant-specific. Backfilled to the Default Company. NOT NULL final state;
  // onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  workers Worker[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-company name uniqueness (was `name @unique`, global).
  @@unique([companyId, name])
  @@index([isArchived])
  // Multi-tenancy: per-company staffing-firm list (active/archived).
  @@index([companyId, isArchived])
}

// ─────────────────────────────────────────────────────────────────────────────
// Attendance / Working Hours  [v1]  (PRD FR-MGR-ATT)
// ─────────────────────────────────────────────────────────────────────────────

// Exactly one record per worker/day (FR-MGR-ATT-4) — enforced by @@unique.
// WorkingHours aggregates (day/week/month) are DERIVED from these rows at query time.
model AttendanceRecord {
  id       String         @id @default(cuid())
  worker   Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId String
  site     Site?          @relation(fields: [siteId], references: [id])
  siteId   String?
  date     DateTime       @db.Date
  type     AttendanceType
  hours    Decimal?       @db.Decimal(6, 2) // hours when type = ATTENDANCE
  notes    String?

  // Back-link to the WorkerRequest whose APPROVAL created this record (VACATION effect).
  // NULLABLE — manually-created attendance has no source request; only approval-created
  // rows are tagged. onDelete: SetNull keeps financial/attendance history if the request
  // is deleted. Enables SAFE, precise reversal on re-decide (APPROVED→REJECTED) without
  // matching by workerId+date. (Servio sets/queries requestId; schema only.)
  sourceRequest WorkerRequest? @relation("RequestEffect", fields: [requestId], references: [id], onDelete: SetNull)
  requestId     String?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Very high row count, queried by
  // date range per company; siteId is nullable so company CANNOT derive via Site.
  // Backfilled via Worker.companyId (workerId). NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workerId, date]) // exclusivity guard (FR-MGR-ATT-4)
  @@index([siteId, date])
  @@index([date])
  @@index([requestId])
  // Multi-tenancy: per-company date-range scans (reports) without a worker->company join.
  @@index([companyId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// Compensation: wage rules  [v1]  (PRD FR-MGR-PAY)
// SalaryRuleEngine SalaryInput/SalaryResult are DTOs (@sitelink/shared/salary.ts),
// not persisted models — results are computed on demand (FR-MGR-PAY-4).
// ─────────────────────────────────────────────────────────────────────────────

model ProfessionWageRate {
  id         String         @id @default(cuid())
  profession Profession
  wage       Decimal        @db.Decimal(12, 2)
  rateType   RateType       @default(HOURLY)
  calcMode   SalaryCalcMode @default(FIXED)
  currency   String         @default("ILS")
  site       Site?          @relation(fields: [siteId], references: [id])
  siteId     String?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Wage rules are tenant policy;
  // siteId is nullable (company-wide rate) so company CANNOT derive via Site.
  // Backfilled to the Default Company. NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-company uniqueness: Company A and B may each define the same (profession, siteId=null)
  // company-wide slot without colliding (was @@unique([profession, siteId])).
  @@unique([companyId, profession, siteId])
  // Replaces @@index([profession]) — company is the leading scope filter.
  @@index([companyId, profession])
}

// ─────────────────────────────────────────────────────────────────────────────
// Financial ledgers  [v1]  (PRD FR-MGR-LOAN, FR-MGR-ADV, FR-MGR-PNL)
// ─────────────────────────────────────────────────────────────────────────────

model Loan {
  id          String   @id @default(cuid())
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ILS")
  date        DateTime @db.Date
  notes       String?
  outstanding Decimal  @db.Decimal(12, 2)

  // Back-link to the WorkerRequest whose APPROVAL created this loan (LOAN effect).
  // NULLABLE — manually-created loans have no source request. onDelete: SetNull keeps
  // financial history if the request is deleted. Enables SAFE reversal by requestId.
  sourceRequest WorkerRequest? @relation("RequestEffect", fields: [requestId], references: [id], onDelete: SetNull)
  requestId     String?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Financial ledger; per-company P&L
  // and reports scan by date. Backfilled via Worker.companyId (workerId).
  // NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([date])
  @@index([requestId])
  // Multi-tenancy: per-company ledger scans by date.
  @@index([companyId, date])
}

model AdvancePayment {
  id          String   @id @default(cuid())
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId    String
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("ILS")
  date        DateTime @db.Date
  notes       String?
  outstanding Decimal  @db.Decimal(12, 2)

  // Back-link to the WorkerRequest whose APPROVAL created this advance (ADVANCE effect).
  // NULLABLE — manually-created advances have no source request. onDelete: SetNull keeps
  // financial history if the request is deleted. Enables SAFE reversal by requestId.
  sourceRequest WorkerRequest? @relation("RequestEffect", fields: [requestId], references: [id], onDelete: SetNull)
  requestId     String?

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Same as Loan: per-company financial
  // ledger scanned by date. Backfilled via Worker.companyId (workerId).
  // NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([date])
  @@index([requestId])
  // Multi-tenancy: per-company ledger scans by date.
  @@index([companyId, date])
}

// Site-level P&L snapshot (FR-MGR-PNL). May be computed on-demand or persisted.
model ProfitLoss {
  id           String   @id @default(cuid())
  site         Site?    @relation(fields: [siteId], references: [id])
  siteId       String?
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date
  currency     String   @default("ILS")
  revenue      Decimal  @db.Decimal(14, 2) @default(0)
  salaryCost   Decimal  @db.Decimal(14, 2) @default(0)
  loansCost    Decimal  @db.Decimal(14, 2) @default(0)
  advancesCost Decimal  @db.Decimal(14, 2) @default(0)
  otherCost    Decimal  @db.Decimal(14, 2) @default(0)
  netProfit    Decimal  @db.Decimal(14, 2) @default(0)

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Site-level P&L; siteId is nullable
  // (company-wide P&L rows) so company CANNOT derive via Site. Backfilled via Site.companyId
  // (siteId) when set, else the Default Company. NOT NULL final state; onDelete: Restrict.
  // NOTE: this is the SITE-level ProfitLoss, NOT BusinessProfitLoss (billing P&L, customerId).
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([siteId, periodStart, periodEnd])
  // Multi-tenancy: per-company P&L period scans.
  @@index([companyId, periodStart, periodEnd])
}

// ─────────────────────────────────────────────────────────────────────────────
// Request–Approval workflow  [future / modeled]  (PRD §10a FR-REQ)
// Persisted now to avoid migration churn (FR-REQ-3); no Worker/Admin UI in v1.
// ─────────────────────────────────────────────────────────────────────────────

model WorkerRequest {
  id              String        @id @default(cuid())
  worker          Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId        String
  requestedById   String? // Worker user who submitted (v2)
  type            RequestType
  status          RequestStatus @default(PENDING)
  amount          Decimal?      @db.Decimal(12, 2)
  currency        String?
  startDate       DateTime?     @db.Date
  endDate         DateTime?     @db.Date
  notes           String?
  resolvedBy      User?         @relation("RequestResolvedBy", fields: [resolvedById], references: [id])
  resolvedById    String?
  resolvedAt      DateTime?
  resolutionNotes String?

  // Side-effect records created when THIS request was APPROVED (applyApprovalEffect):
  // VACATION → AttendanceRecord(s), LOAN → Loan, ADVANCE → AdvancePayment. Back-relations
  // named "RequestEffect" (distinct from "worker"/"RequestResolvedBy") so a re-decide
  // (APPROVED→REJECTED) can reverse EXACTLY these tagged rows — no unsafe workerId+amount+date
  // matching. Servio owns the tag-on-create + reverse-by-requestId logic (service/endpoint).
  createdLoans      Loan[]             @relation("RequestEffect")
  createdAdvances   AdvancePayment[]   @relation("RequestEffect")
  createdAttendance AttendanceRecord[] @relation("RequestEffect")

  // ── Multi-tenancy (Phase 2) — DIRECT tenant scope. Request inbox is per-company;
  // status/type filters are hot. Backfilled via Worker.companyId (workerId).
  // NOT NULL final state; onDelete: Restrict.
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  companyId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([status])
  @@index([type])
  // Multi-tenancy: per-company request-inbox status/type filters.
  @@index([companyId, status])
  @@index([companyId, type])
}

// ─────────────────────────────────────────────────────────────────────────────
// Foreman worker ratings  [v1]  (PRD FR-FOR-5)
// A FOREMAN rates a worker's performance on a given date. This is a per-event,
// time-series numeric signal (multiple ratings over time, averageable) — distinct
// from Worker.level (WorkerLevel), which is the Manager's single authoritative
// classification. Hence `score` is a free Int on a 1..5 scale, NOT the WorkerLevel
// enum: reusing the enum would conflate a computed reputation trend with the
// manager-set static level and block averaging.
// ─────────────────────────────────────────────────────────────────────────────

model WorkerRating {
  id        String   @id @default(cuid())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId  String
  // The FOREMAN user who authored the rating (named relation to avoid clashing
  // with User's other relations, mirroring WorkerRequest's "RequestResolvedBy").
  foreman   User     @relation("RatingByForeman", fields: [foremanId], references: [id])
  foremanId String
  date      DateTime @db.Date
  score     Int // 1..5 performance rating (validated in the service/DTO layer)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workerId])
  @@index([foremanId])
  @@index([workerId, date])
}

// ─────────────────────────────────────────────────────────────────────────────
// SaaS business layer  [future / modeled]  (PRD §10 FR-BO)
// No Back Office UI in v1; modeled to avoid future migration.
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id           String    @id @default(cuid())
  name         String
  contactEmail String?
  contactPhone String?
  registeredAt DateTime  @default(now())
  leftAt       DateTime?
  isArchived   Boolean   @default(false)
  archivedAt   DateTime?

  billings Billing[]
  usages   Usage[]
  pnl      BusinessProfitLoss[]

  // ── Multi-tenancy (Phase 1) — inverse of the Company↔Customer 1:1 link.
  // A billing Customer MAY be linked to at most one tenant Company (the @unique on
  // Company.customerId enforces at-most-1:1). Optional: a Customer can exist without a
  // Company and vice-versa (the authz boundary is DECOUPLED from the optional billing model).
  company Company?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isArchived])
}

// ─────────────────────────────────────────────────────────────────────────────
// Multi-tenancy — Company (the TENANT)  [v1]  (docs/MULTI-TENANCY-DECISIONS.md)
// The app's primary security boundary. Company → Manager/Foreman/Worker users.
// A Manager sees ONLY same-company data; System Admin (ADMIN) is a super-admin
// above all companies. Every tenant-owned row carries a DIRECT companyId (Phase 1:
// only User; Worker/Site/etc. are Phase 2). This is a NEW model linked 1:1 to the
// billing Customer — NOT a rename — so the authz boundary stays decoupled from the
// nullable/optional billing model (DECISION 1). Follows Site/Customer conventions.
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id   String @id @default(cuid())
  name String

  // Optional 1:1 link to the billing Customer (DECISION 5: enforce 1:1). NULLABLE +
  // @unique makes it AT-MOST-1:1 — a Company MAY link to a Customer; @unique forbids two
  // Companies sharing one Customer. onDelete: SetNull — deleting a billing Customer UNLINKS
  // the tenant (never nukes the Company); a Company is retired only via isArchived
  // soft-archive, never cascade. The Default Company (backfill) leaves customerId NULL.
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?   @unique

  // Tenant lifecycle: retire by SOFT-ARCHIVE, never cascade-delete (users would orphan).
  isArchived Boolean   @default(false)
  archivedAt DateTime?

  // Back-relations: all tenant-owned rows belonging to this Company. Every FK is
  // onDelete: Restrict — a Company with any of these can never be hard-deleted (tenants
  // are retired via isArchived soft-archive). Phase 1 added `users`; Phase 2 adds the rest.
  users               User[]
  workers             Worker[]
  sites               Site[]
  attendanceRecords   AttendanceRecord[]
  workerRequests      WorkerRequest[]
  loans               Loan[]
  advancePayments     AdvancePayment[]
  professionWageRates ProfessionWageRate[]
  personnelCompanies  PersonnelCompany[]
  profitLoss          ProfitLoss[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isArchived])
}

model Billing {
  id          String        @id @default(cuid())
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  status      BillingStatus @default(TRIALING)
  plan        String
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("ILS")
  periodStart DateTime      @db.Date
  periodEnd   DateTime      @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
}

model Usage {
  id          String   @id @default(cuid())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  metric      String
  value       Decimal  @db.Decimal(18, 4)
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, metric])
}

model BusinessProfitLoss {
  id          String    @id @default(cuid())
  customer    Customer? @relation(fields: [customerId], references: [id])
  customerId  String?
  periodStart DateTime  @db.Date
  periodEnd   DateTime  @db.Date
  currency    String    @default("ILS")
  revenue     Decimal   @db.Decimal(14, 2) @default(0)
  cost        Decimal   @db.Decimal(14, 2) @default(0)
  netProfit   Decimal   @db.Decimal(14, 2) @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId, periodStart, periodEnd])
}
