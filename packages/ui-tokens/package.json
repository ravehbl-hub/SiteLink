{
  "name": "@sitelink/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css/tokens.css": "./css/tokens.css",
    "./css/neumorphic.css": "./css/neumorphic.css"
  },
  "files": [
    "dist",
    "css"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./dist/emit-css.js",
    "build:css": "node ./dist/emit-css.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
